{
  "requireExplicitColumns": true,
  "databases": {
    "LASSO": {
      "schemas": {
        "dbo": {
          "tables": {
            "mode": "whitelist",
            "list": ["Player", "Team", "Game", "Coach", "School"],
            "columnAccess": {
              "Player": {
                "mode": "exclusion",
                "columns": ["Grade", "Medical", "SSN", "DateOfBirth"]
              },
              "Coach": {
                "mode": "exclusion",
                "columns": ["Salary", "SSN"]
              }
            }
          }
        },
        "archive": {
          "tables": {
            "mode": "blacklist",
            "list": ["AuditLog", "DeletedRecords", "SensitiveData"]
          }
        }
      }
    },
    "PRISM": {
      "schemas": {
        "*": {
          "tables": {
            "mode": "whitelist",
            "list": ["Player", "School", "Evaluation", "Position"]
          }
        }
      }
    }
  }
}
