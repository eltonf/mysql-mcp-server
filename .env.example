# Database Configuration
# Connect to SQL Server instance (database specified per request)
DB_SERVER=your-server.domain.com

# macOS/Linux with Kerberos (recommended for Mac users)
# Run: kinit username@DOMAIN.COM before starting
DB_USE_KERBEROS=true
DB_DOMAIN=DOMAIN

# OR Windows NTLM Authentication
# DB_TRUSTED_CONNECTION=true
# DB_DOMAIN=DOMAIN

# OR SQL Server Authentication
# DB_USER=username
# DB_PASSWORD=password

# MCP Configuration
MCP_SERVER_NAME=sql-server-tools
MCP_SERVER_VERSION=1.0.0

# Cache Settings
CACHE_TTL=3600
CACHE_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FILE=mcp-server.log