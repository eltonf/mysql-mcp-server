# Database Configuration
# Connect to SQL Server instance (database specified per request)
DB_SERVER=your-server.domain.com

# SQL Server Authentication (works on macOS/Windows/Linux)
# Ask your DBA to create a SQL Server login for you
DB_USER=your_username
DB_PASSWORD=your_password

# OR Windows NTLM Authentication (Windows only)
# DB_TRUSTED_CONNECTION=true
# DB_DOMAIN=DOMAIN

# MCP Configuration
MCP_SERVER_NAME=sql-server-mcp
MCP_SERVER_VERSION=1.0.0

# Access Control
# Set to 'true' to disable data query tools (schema introspection only)
# Set to 'false' or omit to allow data queries when implemented
# Use with Setup-Schema-User.sql for schema-only, Setup-Full-User.sql for full access
SCHEMA_ONLY_MODE=false

# Data Query Settings (only applies when SCHEMA_ONLY_MODE=false)
# Maximum number of rows returned by execute_query tool (default: 50)
MAX_QUERY_ROWS=50
# Query execution timeout in milliseconds (default: 30000 = 30 seconds)
QUERY_TIMEOUT_MS=30000

# Cache Settings
CACHE_TTL=3600
CACHE_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FILE=mcp-server.log