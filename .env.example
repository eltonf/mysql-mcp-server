# Database Configuration
DB_SERVER=localhost
DB_DATABASE=LASSO
DB_USER=username
DB_PASSWORD=password
DB_DOMAIN=DOMAIN
DB_TRUSTED_CONNECTION=true

# MCP Configuration
MCP_SERVER_NAME=sql-server-tools
MCP_SERVER_VERSION=1.0.0

# Cache Settings
CACHE_TTL=3600
CACHE_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FILE=mcp-server.log