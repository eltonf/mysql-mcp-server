# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=app_db
DB_USER=mcp_reader
DB_PASSWORD=change_me

# Optional: set to true for managed MySQL providers that require TLS.
DB_SSL=false

# MCP server metadata
MCP_SERVER_NAME=mysql-mcp-server
MCP_SERVER_VERSION=1.0.0

# Set to true to expose schema/introspection tools only.
SCHEMA_ONLY_MODE=false

# Read query safety
MAX_QUERY_ROWS=100
QUERY_TIMEOUT_MS=30000

# Optional access-control config path. Required before execute_query can run
# unless SCHEMA_ONLY_MODE=true.
# QUERY_ACCESS_CONFIG=/absolute/path/to/query-access.json

# Cache
CACHE_TTL=3600
CACHE_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FILE=mcp-server.log
